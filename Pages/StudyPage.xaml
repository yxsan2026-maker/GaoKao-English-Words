<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GaoKao_English_Words.Pages.StudyPage"
             Title="学习">

    <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="FillAndExpand">
        
        <!-- Progress Bar -->
        <ProgressBar x:Name="ProgressBar" Progress="0" />
        <Label x:Name="ProgressLabel" Text="0 / 0" HorizontalTextAlignment="Center" />

        <!-- Word Card -->
        <Frame BorderColor="#512BD4" CornerRadius="10" Padding="20" HasShadow="True" VerticalOptions="CenterAndExpand">
            <VerticalStackLayout Spacing="20" VerticalOptions="CenterAndExpand">
                
                <!-- English Word -->
                <Label x:Name="EnglishLabel" Text="" FontSize="32" FontAttributes="Bold" TextColor="#512BD4" HorizontalTextAlignment="Center" />

                <!-- Phonetic -->
                <Label x:Name="PhoneticLabel" Text="" FontSize="16" TextColor="#666666" HorizontalTextAlignment="Center" />

                <!-- Part of Speech -->
                <Label x:Name="PosLabel" Text="" FontSize="14" TextColor="#999999" HorizontalTextAlignment="Center" />

                <!-- Divider -->
                <BoxView HeightRequest="1" BackgroundColor="#E0E0E0" />

                <!-- Show Meaning Button -->
                <Button x:Name="ShowMeaningButton" Text="显示含义" Clicked="OnShowMeaningClicked" />

                <!-- Meaning -->
                <StackLayout x:Name="MeaningStack" IsVisible="False" Spacing="10">
                    <Label x:Name="ChineseLabel" Text="" FontSize="20" FontAttributes="Bold" TextColor="#D32F2F" HorizontalTextAlignment="Center" />
                    <Label x:Name="ExampleLabel" Text="" FontSize="14" TextColor="#555555" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" />
                </StackLayout>
            </VerticalStackLayout>
        </Frame>

        <!-- Buttons -->
        <HorizontalStackLayout Spacing="10" HorizontalOptions="FillAndExpand">
            <Button x:Name="IncorrectButton" Text="❌ 不会" BackgroundColor="#D32F2F" TextColor="White" Clicked="OnIncorrectClicked" HorizontalOptions="FillAndExpand" />
            <Button x:Name="CorrectButton" Text="✅ 认识" BackgroundColor="#388E3C" TextColor="White" Clicked="OnCorrectClicked" HorizontalOptions="FillAndExpand" />
        </HorizontalStackLayout>

        <!-- Mark Button -->
        <Button x:Name="MarkButton" Text="⭐ 标记" BackgroundColor="#FFA500" TextColor="White" Clicked="OnMarkClicked" />

        <!-- Study Complete Message -->
        <StackLayout x:Name="CompleteStack" IsVisible="False" VerticalOptions="CenterAndExpand" HorizontalOptions="FillAndExpand">
            <Label Text="🎉 今日学习完成！" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="#388E3C" />
            <Label Text="继续努力，坚持每天学习！" FontSize="16" HorizontalTextAlignment="Center" TextColor="#666666" />
        </StackLayout>
    </VerticalStackLayout>
</ContentPage>
